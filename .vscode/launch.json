{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Sails App",
            "program": "${workspaceFolder}/backend/app.js",
            "cwd": "${workspaceFolder}/backend",
            "skipFiles": [
                "<node_internals>/**",
                "${workspaceFolder}/backend/node_modules/**"
            ],
            "env": {
                "NODE_ENV": "development"
            },
            "console": "integratedTerminal"
        }
    ]
}
